# ── API 키 설정 ───────────────────────────────────────────────────────────────
# 이 파일을 .env로 복사한 뒤 실제 키를 채우세요.
#   cp .env.example .env

# Alibaba Cloud DashScope (Qwen 모델)
# 발급: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API (GPT-4o 등)
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 자체 호스팅 vLLM
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=Qwen3.5-27b
# VLLM_API_KEY=token-abc123   # vLLM에 --api-key 설정한 경우만

# ── Judge 설정 ────────────────────────────────────────────────────────────────
# judge는 Claude Code CLI를 사용합니다.
# 설치: npm install -g @anthropic-ai/claude-code
# 로그인: claude
# 기본 모델: claude-opus-4-6 (run.py --judge-model 로 변경 가능)
